# Documents the environment variables used by the SSMEAS backend.
PORT=4000

# Use DATABASE_URL or the individual PostgreSQL connection fields below.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ssmeas
DB_USER=postgres
DB_PASSWORD=********

# Backend-only credentials for retrieving the latest ThingSpeak channel feed.
THINGSPEAK_CHANNEL_ID=*********
THINGSPEAK_READ_API_KEY=*********

# Automatic alert thresholds.
FILL_WARNING_THRESHOLD=80
FILL_CRITICAL_THRESHOLD=95
GAS_LEVEL_THRESHOLD=300
LOW_BATTERY_THRESHOLD=3.3

# Minutes after a critical sensor reading before its automatic field task is due.
CRITICAL_MAINTENANCE_DELAY_MINUTES=30

# Maintenance vehicle depot used as the route optimization starting point.
DEPOT_LATITUDE=0.3476
DEPOT_LONGITUDE=32.5825

# JWT authentication. Use a long, random secret in production.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h

#device API
DEVICE_API_KEY=replace-with-a-long-random-secret
